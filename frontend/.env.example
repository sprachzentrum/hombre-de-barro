# Strapi
STRAPI_URL=http://localhost:1337
STRAPI_API_TOKEN=

# Public site
NEXT_PUBLIC_STRAPI_URL=http://localhost:1337
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_BASE_PATH=

# Demo content is useful locally. Set this to false in production so that
# deleting or unpublishing CMS entries really removes them from the website.
USE_FALLBACK_CONTENT=true

# Revalidation (ISR) — secret para webhooks de Strapi
REVALIDATE_SECRET=
