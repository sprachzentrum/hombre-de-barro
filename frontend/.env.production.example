# Copy to .env.production before running `npm run build`.
STRAPI_URL=http://127.0.0.1:1337
STRAPI_API_TOKEN=CHANGE_ME_READ_ONLY_TOKEN

# Root-domain deployment:
NEXT_PUBLIC_STRAPI_URL=https://hombredebarro.com
NEXT_PUBLIC_SITE_URL=https://hombredebarro.com
NEXT_PUBLIC_BASE_PATH=

# For https://deutschmate.de/hombredebarro instead use:
# NEXT_PUBLIC_STRAPI_URL=https://deutschmate.de/hombredebarro
# NEXT_PUBLIC_SITE_URL=https://deutschmate.de/hombredebarro
# NEXT_PUBLIC_BASE_PATH=/hombredebarro

USE_FALLBACK_CONTENT=false
REVALIDATE_SECRET=CHANGE_ME
